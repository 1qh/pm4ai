{
  "name": "pm4ai-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "action": "which rg || sudo apt-get install -y ripgrep && sh up.sh && bun run test && cd packages/pm4ai && bun dist/cli.mjs && bun dist/cli.mjs status",
    "build": "turbo build --output-logs=errors-only",
    "check": "lintmax check",
    "clean": "sh clean.sh",
    "fix": "lintmax fix",
    "postinstall": "sherif",
    "prepare": "bunx simple-git-hooks",
    "test": "turbo test --output-logs=errors-only"
  },
  "simple-git-hooks": {
    "pre-commit": "sh up.sh && git add -u"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/bun": "latest",
    "@types/mdx": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "lintmax": "latest",
    "playwright": "latest",
    "postcss": "latest",
    "sherif": "latest",
    "simple-git-hooks": "latest",
    "tailwindcss": "latest",
    "tsdown": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "lintmax"
  ]
}
