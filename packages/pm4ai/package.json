{
  "name": "pm4ai",
  "version": "0.0.36",
  "description": "Agent-first anti-slop project management for TypeScript monorepos",
  "keywords": [
    "bun",
    "lintmax",
    "monorepo",
    "project-manager",
    "sync",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/1qh/pm4ai"
  },
  "license": "MIT",
  "author": "1qh",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./guide": {
      "types": "./dist/guide.d.mts",
      "import": "./dist/guide.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.mts",
      "import": "./dist/schemas.mjs"
    },
    "./watch-state": {
      "types": "./dist/watch-state.d.mts",
      "import": "./dist/watch-state.mjs"
    }
  },
  "bin": {
    "pm4ai": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "postpublish": "bunx pm4ai@latest cleanup",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "latest",
    "ink-spinner": "latest",
    "react": "latest",
    "zod": "latest"
  },
  "requiredDevDeps": [
    "lintmax",
    "sherif",
    "simple-git-hooks",
    "tsdown",
    "turbo",
    "typescript"
  ]
}
